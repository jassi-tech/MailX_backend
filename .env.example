PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mailflow

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
MAGIC_LINK_EXPIRES_IN=15m

# Encryption (32-byte hex for AES-256-GCM - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here_replace_me

# System SMTP (for sending magic link emails)
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=your_email@gmail.com
SYSTEM_SMTP_PASS=your_app_password
SYSTEM_SMTP_FROM=MailFlow <your_email@gmail.com>

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
